generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CHECKING
  SAVINGS
  INVESTMENT
  CREDIT_CARD
  CASH
}

enum TransactionType {
  INFLOW
  OUTFLOW
}

enum RecurrenceInterval {
  WEEKLY
  MONTHLY
  YEARLY
}

enum DebtStatus {
  PENDING
  PARTIAL
  PAID
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String             @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?
  preferredCurrency String             @default("BRL")
  createdAt         DateTime           @default(now())
  accounts          Account[]
  sessions          Session[]
  financialAccounts FinancialAccount[]
  categories        Category[]
  transactions      Transaction[]
  recurringExpenses RecurringExpense[]
  debts             Debt[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model FinancialAccount {
  id             String         @id @default(cuid())
  name           String
  type           AccountType
  currency       String
  initialBalance Decimal        @default(0) @db.Decimal(18, 2)
  userId         String
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  snapshots      BalanceSnapshot[]

  @@index([userId])
}

model BalanceSnapshot {
  id        String           @id @default(cuid())
  amount    Decimal          @db.Decimal(18, 2)
  createdAt DateTime         @default(now())
  accountId String
  account   FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model Category {
  id                String             @id @default(cuid())
  name              String
  color             String             @default("#868e96")
  isRecurring       Boolean            @default(false)
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  recurringExpenses RecurringExpense[]

  @@index([userId])
}

model Transaction {
  id               String           @id @default(cuid())
  amount           Decimal          @db.Decimal(18, 2)
  type             TransactionType
  date             DateTime
  description      String
  fxRateAtCreation Decimal          @default(1) @db.Decimal(18, 6)
  accountId        String
  categoryId       String?
  userId           String
  createdAt        DateTime         @default(now())
  account          FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category         Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([accountId])
  @@index([categoryId])
}

model RecurringExpense {
  id          String             @id @default(cuid())
  name        String
  amount      Decimal            @db.Decimal(18, 2)
  currency    String
  interval    RecurrenceInterval @default(MONTHLY)
  nextDueDate DateTime
  active      Boolean            @default(true)
  categoryId  String?
  userId      String
  category    Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([categoryId])
}

model Debt {
  id          String        @id @default(cuid())
  debtorName  String
  description String?
  totalAmount Decimal       @db.Decimal(18, 2)
  currency    String
  dueDate     DateTime?
  status      DebtStatus    @default(PENDING)
  userId      String
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments    DebtPayment[]

  @@index([userId])
}

model DebtPayment {
  id               String   @id @default(cuid())
  amount           Decimal  @db.Decimal(18, 2)
  paymentDate      DateTime
  fxRateAtCreation Decimal  @default(1) @db.Decimal(18, 6)
  debtId           String
  debt             Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
}
